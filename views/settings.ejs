<%- include('partials/header', { title: title }) %>

<div id="app-layout">
  <%- include('partials/sidebar', { activePage: '/settings' }) %>

  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title">⚙️ System Settings</div>
    </div>

    <div class="page-content">
      <div class="card" style="max-width:640px;">
        <div class="card-header">
          <span class="card-title">Company Information</span>
        </div>
        <form method="POST" action="/settings">
          <div class="card-body">
            <div class="form-group">
              <label>Company Name</label>
              <input type="text" name="name"
                value="<%= settings ? settings.name : '' %>" required>
            </div>
            <div class="form-group">
              <label>Email Address</label>
              <input type="email" name="email"
                value="<%= settings ? settings.email : '' %>" required>
            </div>
            <div class="form-group">
              <label>Contact Number</label>
              <input type="text" name="contact"
                value="<%= settings ? settings.contact : '' %>" required>
            </div>
            <div class="form-group">
              <label>Office Address</label>
              <textarea name="address" required><%= settings ? settings.address : '' %></textarea>
            </div>
          </div>
          <div class="modal-footer" style="border-top:1px solid var(--border);">
            <button type="submit" class="btn btn-primary">Save Settings</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
