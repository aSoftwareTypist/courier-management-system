<%- include('partials/header', { title: title }) %>

<div id="app-layout">
  <%- include('partials/sidebar', { activePage: '/branches' }) %>

  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title">🏢 Branches</div>
      <% if (currentUser && currentUser.role === 'ADMIN') { %>
        <button class="btn btn-primary btn-sm" onclick="openModal('create-branch-modal')">+ New Branch</button>
      <% } %>
    </div>

    <div class="page-content">
      <div class="table-wrap">
        <div class="table-head">
          <span class="table-title">All Branches (<%= branches.length %>)</span>
        </div>
        <% if (branches.length === 0) { %>
          <div class="empty-state">
            <div class="icon">🏢</div>
            <h3>No branches yet</h3>
            <p>Add your first branch using the button above.</p>
          </div>
        <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Code</th>
              <th>Address</th>
              <th>City / State</th>
              <th>Contact</th>
              <th>Staff</th>
              <th>Parcels</th>
              <% if (currentUser && currentUser.role === 'ADMIN') { %><th>Actions</th><% } %>
            </tr>
          </thead>
          <tbody>
            <% branches.forEach(b => { %>
            <tr>
              <td><span class="badge badge-admin"><%= b.branchCode %></span></td>
              <td class="text-sm"><%= b.street %></td>
              <td class="text-sm"><%= b.city %>, <%= b.state %>, <%= b.country %></td>
              <td class="text-sm"><%= b.contact %></td>
              <td class="text-sm"><%= b._count.users %></td>
              <td class="text-sm"><%= b._count.fromParcels %></td>
              <% if (currentUser && currentUser.role === 'ADMIN') { %>
              <td>
                <div class="flex gap-2">
                  <button class="btn btn-outline btn-sm"
                    onclick="openEditBranch(<%= JSON.stringify(b) %>)">Edit</button>
                  <form method="POST" action="/branches/<%= b.id %>/delete"
                    onsubmit="return confirm('Delete branch <%= b.branchCode %>?')">
                    <button type="submit" class="btn btn-danger btn-sm">Del</button>
                  </form>
                </div>
              </td>
              <% } %>
            </tr>
            <% }); %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Create Branch Modal -->
<div class="modal-overlay" id="create-branch-modal">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title">New Branch</span>
      <button class="modal-close" onclick="closeModal('create-branch-modal')">✕</button>
    </div>
    <form method="POST" action="/branches">
      <div class="modal-body">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div class="form-group">
            <label>Branch Code</label>
            <input type="text" name="branchCode" placeholder="e.g. KTM-01" required>
          </div>
          <div class="form-group">
            <label>Contact</label>
            <input type="text" name="contact" required>
          </div>
          <div class="form-group" style="grid-column:1/-1;">
            <label>Street</label>
            <input type="text" name="street" required>
          </div>
          <div class="form-group">
            <label>City</label>
            <input type="text" name="city" required>
          </div>
          <div class="form-group">
            <label>State / Province</label>
            <input type="text" name="state" required>
          </div>
          <div class="form-group">
            <label>ZIP Code</label>
            <input type="text" name="zipCode" required>
          </div>
          <div class="form-group">
            <label>Country</label>
            <input type="text" name="country" value="Nepal" required>
          </div>
          <div class="form-group">
            <label>Latitude (optional)</label>
            <input type="number" name="latitude" step="any" placeholder="27.7172">
          </div>
          <div class="form-group">
            <label>Longitude (optional)</label>
            <input type="number" name="longitude" step="any" placeholder="85.3240">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('create-branch-modal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Create Branch</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Branch Modal -->
<div class="modal-overlay" id="edit-branch-modal">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title">Edit Branch</span>
      <button class="modal-close" onclick="closeModal('edit-branch-modal')">✕</button>
    </div>
    <form method="POST" id="edit-branch-form">
      <div class="modal-body">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div class="form-group">
            <label>Branch Code</label>
            <input type="text" name="branchCode" id="eb-code" required>
          </div>
          <div class="form-group">
            <label>Contact</label>
            <input type="text" name="contact" id="eb-contact" required>
          </div>
          <div class="form-group" style="grid-column:1/-1;">
            <label>Street</label>
            <input type="text" name="street" id="eb-street" required>
          </div>
          <div class="form-group">
            <label>City</label>
            <input type="text" name="city" id="eb-city" required>
          </div>
          <div class="form-group">
            <label>State</label>
            <input type="text" name="state" id="eb-state" required>
          </div>
          <div class="form-group">
            <label>ZIP Code</label>
            <input type="text" name="zipCode" id="eb-zip" required>
          </div>
          <div class="form-group">
            <label>Country</label>
            <input type="text" name="country" id="eb-country" required>
          </div>
          <div class="form-group">
            <label>Latitude</label>
            <input type="number" name="latitude" id="eb-lat" step="any">
          </div>
          <div class="form-group">
            <label>Longitude</label>
            <input type="number" name="longitude" id="eb-lng" step="any">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline" onclick="closeModal('edit-branch-modal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<script>
function openEditBranch(b) {
  document.getElementById('edit-branch-form').action = '/branches/' + b.id + '/edit';
  document.getElementById('eb-code').value = b.branchCode;
  document.getElementById('eb-contact').value = b.contact;
  document.getElementById('eb-street').value = b.street;
  document.getElementById('eb-city').value = b.city;
  document.getElementById('eb-state').value = b.state;
  document.getElementById('eb-zip').value = b.zipCode;
  document.getElementById('eb-country').value = b.country;
  document.getElementById('eb-lat').value = b.latitude ?? '';
  document.getElementById('eb-lng').value = b.longitude ?? '';
  openModal('edit-branch-modal');
}
</script>

<%- include('partials/footer') %>
