<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= status %> <%= title %> | Courier CMS</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="error-page">
  <div class="error-code"><%= status %></div>
  <h1 style="font-size:1.5rem;font-weight:800;margin-bottom:0.5rem;"><%= title %></h1>
  <p class="error-msg"><%= message %></p>
  <div class="flex gap-3 justify-center">
    <a href="javascript:history.back()" class="btn btn-outline">← Go Back</a>
    <a href="/dashboard" class="btn btn-primary">Go to Dashboard</a>
  </div>
  <% if (locals.stack && stack) { %>
    <pre style="margin-top:2rem;text-align:left;font-size:0.75rem;background:#f1f5f9;padding:1rem;border-radius:8px;max-width:700px;overflow-x:auto;color:#64748b;"><%= stack %></pre>
  <% } %>
</div>
<script src="/js/main.js"></script>
</body>
</html>
