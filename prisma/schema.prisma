generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  CUSTOMER
}

enum ParcelStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum RouteStatus {
  ACTIVE
  INACTIVE
  COMPLETED
}

enum VehicleType {
  MOTORCYCLE
  VAN
  TRUCK
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  role      UserRole @default(STAFF)
  branchId  Int?
  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
}

model Branch {
  id          Int      @id @default(autoincrement())
  branchCode  String   @unique
  street      String
  city        String
  state       String
  zipCode     String
  country     String
  contact     String
  latitude    Float?
  longitude   Float?
  users       User[]
  fromParcels Parcel[] @relation("FromBranch")
  toParcels   Parcel[] @relation("ToBranch")
}

model Parcel {
  id              Int          @id @default(autoincrement())
  trackingNumber  String       @unique
  senderName      String
  senderPhone     String
  senderAddress   String
  receiverName    String
  receiverPhone   String
  receiverAddress String
  weight          Float?
  status          ParcelStatus @default(PENDING)
  fromBranchId    Int
  toBranchId      Int
  fromBranch      Branch       @relation("FromBranch", fields: [fromBranchId], references: [id])
  toBranch        Branch       @relation("ToBranch", fields: [toBranchId], references: [id])
  tracks          ParcelTrack[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model ParcelTrack {
  id        Int          @id @default(autoincrement())
  parcelId  Int
  parcel    Parcel       @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  status    ParcelStatus
  note      String?
  location  String?
  createdAt DateTime     @default(now())
}

model Route {
  id            Int         @id @default(autoincrement())
  vehicleType   VehicleType @default(VAN)
  startLocation String
  endLocation   String
  waypoints     Json?
  distance      Float?
  estimatedTime Float?
  status        RouteStatus @default(ACTIVE)
  createdAt     DateTime    @default(now())
}

model SystemSetting {
  id      Int    @id @default(autoincrement())
  name    String
  email   String
  contact String
  address String
}
